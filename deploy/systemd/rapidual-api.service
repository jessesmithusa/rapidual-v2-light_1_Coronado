[Unit]
Description=Rapidual Coronado franchise API (127.0.0.1:9410)
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
EnvironmentFile=/etc/rapidual/rapidual.env
WorkingDirectory=/var/apps/rapidual-v2-light_1_Coronado/apps/api
ExecStart=/usr/bin/node dist/apps/api/src/server.js
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
