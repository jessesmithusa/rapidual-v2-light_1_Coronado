# ── Supabase ───────────────────────────────────────────────
# Public anon key is safe to ship in the client. Service role key NEVER goes in the app.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Mapbox ─────────────────────────────────────────────────
# Public token (pk.*) for the SDK. Restrict by URL/bundle in the Mapbox dashboard.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_PUBLIC_TOKEN
# Secret download token (sk.*) — used only by EAS/native build to fetch the SDK. Not bundled.
MAPBOX_DOWNLOAD_TOKEN=sk.YOUR_SECRET_DOWNLOAD_TOKEN

# ── Stripe (publishable only in client) ────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
# Secret key lives in Supabase Edge Functions / backend env, NOT here.

# Optional — crash reporting (leave unset to disable)
EXPO_PUBLIC_SENTRY_DSN=
